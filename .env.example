# OVH VPS plan code to watch
# vps-2025-model1 = VPS-1, vps-2025-model2 = VPS-2, etc.
PLAN_CODE=vps-2025-model1

# OVH subsidiary (WE = Western Europe)
OVH_SUBSIDIARY=WE

# Datacenters to watch (comma-separated)
# Available: WAW (Warsaw), UK (London), DE (Frankfurt), GRA, SBG, BHS, SGP, SYD
ZONES=WAW,DE

# Poll interval in seconds (180 = every 3 minutes)
CHECK_INTERVAL=180

# Telegram bot credentials
# Get your token from @BotFather on Telegram
# Get your chat ID from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# OS alert toggles
ALERT_LINUX=true
ALERT_WINDOWS=false
